#!/usr/bin/env sh
# The official Gradle wrapper JAR is generated by `flutter create .`.
# Run `flutter create . --platforms=android` once if this file is used locally
# before the wrapper JAR exists.
DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ ! -f "$DIR/gradle/wrapper/gradle-wrapper.jar" ]; then
  echo "Missing gradle-wrapper.jar. Run: flutter create . --platforms=android --project-name=udrive_mobile --org=com.udrive"
  exit 1
fi
exec java -classpath "$DIR/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
