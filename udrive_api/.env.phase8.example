DATABASE_URL=Host=localhost;Port=5432;Database=udrive;Username=postgres;Password=postgres
AUTO_APPLY_MIGRATIONS=true
ENABLE_SWAGGER=true
ALLOWED_ORIGINS=https://udrive-mobile-production.up.railway.app,https://udrive-admin-production.up.railway.app

# Replace all development secrets before a public production launch.
JWT_ISSUER=udrive-api
JWT_AUDIENCE=udrive-clients
JWT_SIGNING_KEY=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30
OTP_HASH_SECRET=replace-with-a-long-random-secret
IDENTITY_HASH_SECRET=replace-with-a-different-long-random-secret

# Phase 8 testing provider. The code is 1234 unless overridden.
OTP_PROVIDER=Development
DEVELOPMENT_OTP_CODE=1234
EXPOSE_DEVELOPMENT_OTP=false

# Attach a Railway volume at /data/uploads.
UPLOAD_ROOT=/data/uploads
